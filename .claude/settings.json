{
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.fish"
  },
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "WebFetch(domain:npmx.dev)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-github-webfetch.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-npmjs-webfetch.sh"
          }
        ]
      }
    ]
  }
}
